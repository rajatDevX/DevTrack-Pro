<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register | DevTrack Pro</title>
    <link rel="stylesheet" href="/css/app.css">
    <script src="/js/theme.js" defer></script>
</head>
<body>

<div class="container">
    <div class="card auth-card">
        <div class="dashboard-header" style="margin-bottom: 20px;">
            <div>
                <h1>Create account</h1>
                <p class="subtitle">Start tracking your dev projects</p>
            </div>
            <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">🌙</button>
        </div>

        <% if (flash) { %>
            <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
        <% } %>

        <form method="POST" action="/register">
            <div class="field">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" placeholder="Your name" required>
            </div>
            <div class="field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required>
            </div>
            <div class="field">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="At least 6 characters" minlength="6" required>
            </div>
            <button type="submit" class="btn" style="width: 100%; justify-content: center;">Register</button>
        </form>

        <p class="auth-footer">
            Already have an account? <a href="/login">Login</a>
        </p>
    </div>
</div>

</body>
</html>
