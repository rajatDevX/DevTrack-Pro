<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | DevTrack Pro</title>
    <link rel="stylesheet" href="/css/app.css">
    <script src="/js/theme.js" defer></script>
</head>
<body>

<div class="container">
    <div class="card auth-card">
        <div class="dashboard-header" style="margin-bottom: 20px;">
            <div>
                <h1>DevTrack Pro</h1>
                <p class="subtitle">Sign in to manage your projects</p>
            </div>
            <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">🌙</button>
        </div>

        <% if (flash) { %>
            <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
        <% } %>

        <form method="POST" action="/login">
            <div class="field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required>
            </div>
            <div class="field">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Your password" required>
            </div>
            <button type="submit" class="btn" style="width: 100%; justify-content: center;">Login</button>
        </form>

        <p class="auth-footer">
            New user? <a href="/register">Create an account</a>
        </p>
    </div>
</div>

</body>
</html>
