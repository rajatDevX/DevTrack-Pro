<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | DevTrack Pro</title>
    <link rel="stylesheet" href="/css/app.css">
    <script src="/js/theme.js" defer></script>
</head>
<body>

<div class="container">

    <div class="dashboard-header">
        <div>
            <h1>My Projects</h1>
            <p class="subtitle">Welcome back, <%= user.name || user.email %></p>
        </div>
        <div class="header-actions">
            <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">🌙</button>
            <a href="/logout" class="btn btn-secondary btn-sm">Logout</a>
        </div>
    </div>

    <% if (flash) { %>
        <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <section class="stats-grid">
        <div class="stat-card">
            <strong><%= stats.total %></strong>
            <span>Total</span>
        </div>
        <div class="stat-card">
            <strong><%= stats.planned %></strong>
            <span>Planned</span>
        </div>
        <div class="stat-card">
            <strong><%= stats.inProgress %></strong>
            <span>In Progress</span>
        </div>
        <div class="stat-card">
            <strong><%= stats.completed %></strong>
            <span>Completed</span>
        </div>
        <div class="stat-card">
            <strong><%= stats.highPriority %></strong>
            <span>High Priority</span>
        </div>
        <div class="stat-card">
            <strong><%= stats.overdue %></strong>
            <span>Overdue</span>
        </div>
    </section>

    <section class="filter-bar">
        <form method="GET" action="/dashboard">
            <div class="filter-grid">
                <input
                    type="search"
                    name="q"
                    placeholder="Search by title or description..."
                    value="<%= filters.q %>"
                >
                <select name="status">
                    <option value="">All statuses</option>
                    <option value="Planned" <%= filters.status === 'Planned' ? 'selected' : '' %>>Planned</option>
                    <option value="In Progress" <%= filters.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                    <option value="Completed" <%= filters.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                </select>
                <select name="priority">
                    <option value="">All priorities</option>
                    <option value="Low" <%= filters.priority === 'Low' ? 'selected' : '' %>>Low</option>
                    <option value="Medium" <%= filters.priority === 'Medium' ? 'selected' : '' %>>Medium</option>
                    <option value="High" <%= filters.priority === 'High' ? 'selected' : '' %>>High</option>
                </select>
                <button type="submit" class="btn">Filter</button>
            </div>
            <% if (filters.q || filters.status || filters.priority) { %>
                <p style="margin: 12px 0 0;">
                    <a href="/dashboard">Clear filters</a>
                    &middot;
                    <%= projects.length %> result<%= projects.length === 1 ? '' : 's' %>
                </p>
            <% } %>
        </form>
    </section>

    <h2 class="section-title">Create New Project</h2>

    <div class="card" style="margin-bottom: 28px;">
        <form method="POST" action="/project">
            <div class="field">
                <label for="new-title">Title</label>
                <input type="text" id="new-title" name="title" placeholder="Project title" required>
            </div>
            <div class="field">
                <label for="new-description">Description</label>
                <textarea id="new-description" name="description" rows="3" placeholder="What are you building?" required></textarea>
            </div>
            <div class="form-grid">
                <div class="field" style="margin-bottom: 0;">
                    <label for="new-status">Status</label>
                    <select id="new-status" name="status">
                        <option value="Planned">Planned</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>
                <div class="field" style="margin-bottom: 0;">
                    <label for="new-priority">Priority</label>
                    <select id="new-priority" name="priority">
                        <option value="Low">Low</option>
                        <option value="Medium" selected>Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>
                <div class="field" style="margin-bottom: 0;">
                    <label for="new-due">Due date</label>
                    <input type="date" id="new-due" name="dueDate">
                </div>
            </div>
            <div class="project-actions">
                <button type="submit" class="btn">Create Project</button>
            </div>
        </form>
    </div>

    <h2 class="section-title">Project List</h2>

    <% if (projects.length === 0) { %>
        <div class="empty-state card">
            <% if (filters.q || filters.status || filters.priority) { %>
                <p>No projects match your filters.</p>
            <% } else { %>
                <p>No projects yet. Create your first one above.</p>
            <% } %>
        </div>
    <% } else { %>
        <% projects.forEach(project => {
            const isOverdue = project.dueDate && project.status !== 'Completed' && project.dueDate < now;
            const isDueSoon = project.dueDate && project.status !== 'Completed' && !isOverdue && project.dueDate <= threeDaysFromNow;
        %>
            <article class="project-card">
                <div class="project-topline">
                    <h3><%= project.title %></h3>
                    <div class="badge-row" style="margin: 0;">
                        <% if (project.dueDate) { %>
                            <% if (isOverdue) { %>
                                <span class="badge overdue">Overdue <%= project.dueDate.toISOString().slice(0, 10) %></span>
                            <% } else if (isDueSoon) { %>
                                <span class="badge due-soon">Due soon <%= project.dueDate.toISOString().slice(0, 10) %></span>
                            <% } else { %>
                                <span class="badge">Due <%= project.dueDate.toISOString().slice(0, 10) %></span>
                            <% } %>
                        <% } %>
                    </div>
                </div>

                <div class="badge-row">
                    <span class="badge <%= project.status === 'Completed' ? 'status-completed' : '' %>">
                        <%= project.status || 'Planned' %>
                    </span>
                    <span class="badge <%= project.priority === 'High' ? 'priority-high' : '' %>">
                        <%= project.priority || 'Medium' %> priority
                    </span>
                </div>

                <p class="project-description"><%= project.description %></p>

                <form method="POST" action="/project/status/<%= project._id %>" class="project-actions">
                    <select name="status" aria-label="Quick status update">
                        <option value="Planned" <%= project.status === 'Planned' ? 'selected' : '' %>>Planned</option>
                        <option value="In Progress" <%= project.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                        <option value="Completed" <%= project.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                    </select>
                    <button type="submit" class="btn btn-secondary btn-sm">Update status</button>
                    <button type="button" class="btn btn-secondary btn-sm toggle-edit" data-target="edit-<%= project._id %>">
                        Edit details
                    </button>
                </form>

                <form
                    id="edit-<%= project._id %>"
                    class="edit-form"
                    method="POST"
                    action="/project/edit/<%= project._id %>"
                >
                    <input type="text" name="title" value="<%= project.title %>" required>
                    <textarea name="description" rows="3" required><%= project.description %></textarea>
                    <div class="form-grid">
                        <select name="status">
                            <option value="Planned" <%= project.status === 'Planned' ? 'selected' : '' %>>Planned</option>
                            <option value="In Progress" <%= project.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                            <option value="Completed" <%= project.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                        </select>
                        <select name="priority">
                            <option value="Low" <%= project.priority === 'Low' ? 'selected' : '' %>>Low</option>
                            <option value="Medium" <%= project.priority === 'Medium' ? 'selected' : '' %>>Medium</option>
                            <option value="High" <%= project.priority === 'High' ? 'selected' : '' %>>High</option>
                        </select>
                        <input
                            type="date"
                            name="dueDate"
                            value="<%= project.dueDate ? project.dueDate.toISOString().slice(0, 10) : '' %>"
                        >
                    </div>
                    <div class="project-actions">
                        <button type="submit" class="btn">Save changes</button>
                    </div>
                </form>

                <form
                    class="project-actions"
                    method="POST"
                    action="/project/delete/<%= project._id %>"
                    onsubmit="return confirm('Delete this project?');"
                >
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
            </article>
        <% }) %>
    <% } %>

</div>

<script>
    document.querySelectorAll(".toggle-edit").forEach(function (button) {
        button.addEventListener("click", function () {
            var form = document.getElementById(button.dataset.target);
            if (!form) return;
            form.classList.toggle("is-open");
            button.textContent = form.classList.contains("is-open") ? "Hide edit" : "Edit details";
        });
    });
</script>

</body>
</html>
